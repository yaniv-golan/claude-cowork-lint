{
  "name": "claude-cowork-lint",
  "version": "0.1.0",
  "description": "Validate skill/plugin/agent repos against the Claude Cowork runtime contract (Node.js port).",
  "keywords": [
    "claude",
    "claude-cowork",
    "operon",
    "skill",
    "plugin",
    "linter",
    "contract"
  ],
  "homepage": "https://github.com/yaniv-golan/claude-cowork-lint#readme",
  "bugs": "https://github.com/yaniv-golan/claude-cowork-lint/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaniv-golan/claude-cowork-lint.git"
  },
  "author": "Yaniv Golan",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "contracts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-reporter=spec dist/**/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  }
}
